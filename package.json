{
  "name": "fetchui",
  "version": "0.0.0",
  "description": "FetchUI is a CLI tool that lets you fetch, copy and inject fully customizable UI components directly into your codebase. No runtime UI library, no lock-in — just your code.",
  "keywords": [
    "ui",
    "components",
    "cli",
    "frontend",
    "design-system",
    "snippets",
    "custom-ui",
    "codegen",
    "fetch",
    "react",
    "vue",
    "svelte"
  ],
  "homepage": "https://github.com/kevbesset/fetchui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevbesset/fetchui.git"
  },
  "bugs": {
    "url": "https://github.com/kevbesset/fetchui/issues"
  },
  "author": "Kev Bisset <kevbesset@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "fetchui": "bin/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "~10.5.1",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "sass-embedded": "^1.97.0",
    "typescript": "~5.9.0",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.1.5"
  }
}
